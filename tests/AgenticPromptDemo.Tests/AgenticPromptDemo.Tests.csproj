<Project Sdk="MSTest.Sdk/4.2.3">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <IsPackable>false</IsPackable>
    <OutputType>Exe</OutputType>
  </PropertyGroup>

  <ItemGroup>
    <!-- Reference the demo so we can drive its widgets directly.
         The demo's PublishAot setting only matters at publish time, so a
         test ProjectReference is fine. -->
    <ProjectReference Include="..\..\samples\AgenticPromptDemo\AgenticPromptDemo.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Hex1b.Automation" />
  </ItemGroup>

</Project>
