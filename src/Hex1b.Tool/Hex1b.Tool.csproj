<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591</NoWarn>

    <!-- Embed source code for debugging -->
    <EmbedAllSources>true</EmbedAllSources>
    <DebugType>embedded</DebugType>
    <DebugSymbols>true</DebugSymbols>

    <!-- .NET Tool packaging -->
    <PackAsTool>true</PackAsTool>
    <IsPackable>true</IsPackable>
    <ToolCommandName>hex1b</ToolCommandName>

    <!-- Package Metadata -->
    <PackageId>Hex1b.Tool</PackageId>
    <Title>Hex1b CLI Tool</Title>
    <Authors>Mitch Denny</Authors>
    <Copyright>Copyright (c) 2024 Mitch Denny</Copyright>
    <Description>Command-line tool for managing and interacting with Hex1b terminal applications. Provides terminal hosting, screen capture, input injection, widget tree inspection, and more.</Description>
    <PackageTags>hex1b;tui;terminal;cli;diagnostics;automation</PackageTags>

    <!-- License -->
    <PackageLicenseExpression>MIT</PackageLicenseExpression>

    <!-- Repository -->
    <RepositoryUrl>https://github.com/mitchdenny/hex1b</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://github.com/mitchdenny/hex1b</PackageProjectUrl>

    <!-- Additional Package Settings -->
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Hex1b.Tool.Tests" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
    <None Include="../../THIRD-PARTY-NOTICES.txt" Pack="true" PackagePath="/" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Fonts/CaskaydiaCoveNerdFontMono-Regular.ttf" LogicalName="Hex1b.Tool.Fonts.CaskaydiaCoveNerdFontMono-Regular.ttf" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="SkiaSharp" Version="3.116.1" />
    <PackageReference Include="SkiaSharp.NativeAssets.Linux.NoDependencies" Version="3.116.1" />
    <PackageReference Include="Svg.Skia" Version="2.0.0.4" />
    <PackageReference Include="System.CommandLine" Version="2.0.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../Hex1b/Hex1b.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\Hex1b\runtimes\win-x64\native\hex1bpty.exe"
          Pack="true"
          Visible="false"
          Condition="Exists('..\Hex1b\runtimes\win-x64\native\hex1bpty.exe')"
          PackagePath="tools\$(TargetFramework)\any\runtimes\win-x64\native\hex1bpty.exe" />
    <None Include="..\Hex1b\obj\windows-pty-shim\win-x64\native\hex1bpty.exe"
          Pack="true"
          Visible="false"
          Condition="!Exists('..\Hex1b\runtimes\win-x64\native\hex1bpty.exe') and Exists('..\Hex1b\obj\windows-pty-shim\win-x64\native\hex1bpty.exe')"
          PackagePath="tools\$(TargetFramework)\any\runtimes\win-x64\native\hex1bpty.exe" />
    <None Include="..\Hex1b\runtimes\win-arm64\native\hex1bpty.exe"
          Pack="true"
          Visible="false"
          Condition="Exists('..\Hex1b\runtimes\win-arm64\native\hex1bpty.exe')"
          PackagePath="tools\$(TargetFramework)\any\runtimes\win-arm64\native\hex1bpty.exe" />
    <None Include="..\Hex1b\obj\windows-pty-shim\win-arm64\native\hex1bpty.exe"
          Pack="true"
          Visible="false"
          Condition="!Exists('..\Hex1b\runtimes\win-arm64\native\hex1bpty.exe') and Exists('..\Hex1b\obj\windows-pty-shim\win-arm64\native\hex1bpty.exe')"
          PackagePath="tools\$(TargetFramework)\any\runtimes\win-arm64\native\hex1bpty.exe" />
  </ItemGroup>

  <PropertyGroup Condition="$([MSBuild]::IsOSPlatform('Windows'))">
    <WindowsPtyShimRid Condition="'$([System.Runtime.InteropServices.RuntimeInformation]::OSArchitecture)' == 'Arm64'">win-arm64</WindowsPtyShimRid>
    <WindowsPtyShimRid Condition="'$(WindowsPtyShimRid)' == ''">win-x64</WindowsPtyShimRid>
  </PropertyGroup>

  <Target Name="CopyWindowsPtyShim"
          AfterTargets="Build"
          Condition="$([MSBuild]::IsOSPlatform('Windows')) and Exists('../Hex1b/obj/windows-pty-shim/$(WindowsPtyShimRid)/native')">
    <ItemGroup>
      <WindowsPtyShimFiles Include="../Hex1b/obj/windows-pty-shim/$(WindowsPtyShimRid)/native/*.*"
                           Exclude="../Hex1b/obj/windows-pty-shim/$(WindowsPtyShimRid)/native/*.pdb;../Hex1b/obj/windows-pty-shim/$(WindowsPtyShimRid)/native/*.dbg;../Hex1b/obj/windows-pty-shim/$(WindowsPtyShimRid)/native/*.map;../Hex1b/obj/windows-pty-shim/$(WindowsPtyShimRid)/native/*.lib;../Hex1b/obj/windows-pty-shim/$(WindowsPtyShimRid)/native/*.exp" />
      <WindowsPtyShimSymbolFiles Include="$(TargetDir)hex1bpty.pdb;$(TargetDir)hex1bpty.dbg;$(TargetDir)hex1bpty.map;$(TargetDir)hex1bpty.lib;$(TargetDir)hex1bpty.exp" />
    </ItemGroup>

    <Copy SourceFiles="@(WindowsPtyShimFiles)"
          DestinationFolder="$(TargetDir)"
          SkipUnchangedFiles="true" />
    <Delete Files="@(WindowsPtyShimSymbolFiles)" TreatErrorsAsWarnings="true" />
  </Target>

</Project>
